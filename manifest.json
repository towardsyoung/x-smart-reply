{
  "manifest_version": 3,
  "name": "X 智能回复",
  "version": "1.0.0",
  "description": "为 X (Twitter) 平台推文生成具有互动性和共鸣感的智能回复",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.openai.com/*",
    "https://*.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings/settings.html",
  "action": {
    "default_title": "X 智能回复设置",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
